# generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# Optional: AI Gateway key (only if you use Vercel AI Gateway)
AI_GATEWAY_API_KEY=

# Local OpenAI-compatible endpoint (LM Studio, vLLM, Ollama OpenAI mode, etc.)
# LM Studio usually serves OpenAI-compatible APIs on /v1
LOCAL_OPENAI_BASE_URL=http://127.0.0.1:1234/v1
LOCAL_OPENAI_API_KEY=lm-studio
LOCAL_OPENAI_MODEL=qwen/qwen3.5-35b-a3b
NEXT_PUBLIC_LOCAL_OPENAI_MODEL=qwen/qwen3.5-35b-a3b
LOCAL_OPENAI_TOOLS_ENABLED=true

# Optional: Python FastAPI RAG backend URL (used by chat + file upload)
RAG_API_URL=http://127.0.0.1:8000

# Local Postgres example:
POSTGRES_URL=postgres://postgres:postgres@127.0.0.1:5432/chatbot

# Local Redis example:
REDIS_URL=redis://127.0.0.1:6379
