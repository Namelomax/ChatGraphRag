# Copy this file to .env.docker before running docker compose.

AUTH_SECRET=change-me-to-a-random-32-byte-secret

# Public URL users hit in the browser (scheme matters for Auth.js cookies).
# Use https:// only behind TLS; plain http:// must stay http (no mixed scheme).
AUTH_URL=http://127.0.0.1
NEXTAUTH_URL=http://127.0.0.1
AUTH_TRUST_HOST=true

POSTGRES_DB=chatbot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

LOCAL_OPENAI_BASE_URL=http://ollama:11434/v1
LOCAL_OPENAI_API_KEY=ollama
LOCAL_OPENAI_MODEL=qwen3:32b
NEXT_PUBLIC_LOCAL_OPENAI_MODEL=qwen3:32b
LOCAL_OPENAI_EMBEDDING_MODEL=nomic-embed-text

OLLAMA_CHAT_MODEL=qwen3:32b
OLLAMA_EMBED_MODEL=nomic-embed-text

RAG_CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:3000
